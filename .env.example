# Local secrets for `npm run dev:netlify` (netlify dev).
# Copy to `.env` and fill in from the AnyCable Plus dashboard.
# `.env` is gitignored — NEVER commit real values. In production these are set
# in the Netlify dashboard (Site settings > Environment variables) instead.

# AnyCable HTTP broadcast endpoint (the functions POST vote events here).
ANYCABLE_BROADCAST_URL=https://YOUR-APP.fly.dev/_broadcast

# AnyCable broadcast key (signs broadcast requests).
ANYCABLE_BROADCAST_KEY=YOUR_BROADCAST_KEY
