# dependencies
node_modules/

# build output
dist/

# slidev / vite caches
.vite/
.slidev/

# playwright browsers (installed locally per CLAUDE.md)
.pw-browsers/

# background-photo candidates (scratch; pick one → public/img/)
scripts/_candidates/

# logs & os cruft
*.log
.DS_Store

# Local Netlify folder
.netlify

# Deno lockfile generated locally by `netlify dev` (edge runtime) — not needed in VCS
deno.lock

# Local secrets for `netlify dev` (AnyCable broadcast URL/key) — NEVER commit
.env
.env.*
!.env.example
